(* --- Grammar file generated using AI --- *)

(* --- Lexical tokens --- *)
IDENTIFIER = letter , { letter | digit | "_" } ;
NUMBER     = digit , { digit } , [ "." , digit , { digit } ] ;
STRING     = ("'" , { any_character_except "'" } , "'")
           | ('"' , { any_character_except '"' } , '"')
           | ('`' , { any_character_except '`' } , '`') ; (* for interpolation *)

COMMENT        = "--" , { any_character_except_newline } ;
MULTILINE_COMMENT = "--[[" , { any_character } , "]]" ;

NEWLINE = "\n" ;

(* --- Types --- *)
TYPE = "number" | "string" | "bool" | "table" | "none" | "nil" ;

(* --- Program structure --- *)
program = { statement } ;

statement = (comment | assignment | function_def | if_statement | expression_statement) , NEWLINE ;

comment = COMMENT | MULTILINE_COMMENT ;

(* --- Assignments --- *)
assignment = IDENTIFIER , "=" , expression ;

(* --- Expressions --- *)
expression = literal
           | IDENTIFIER
           | function_call
           | interpolation ;

literal = NUMBER
        | STRING
        | "true"
        | "false"
        | "none"
        | "nil" ;

interpolation = "`" , { literal | IDENTIFIER | string_content } , "`" ;

string_content = any_character_except "`" ;

(* --- Function definitions --- *)
function_def = "function" , IDENTIFIER , "(" , [ parameters ] , ")" , [ "->" , type_union ] , ":" , NEWLINE , { statement } , "return" , expression ;

parameters = parameter , { "," , parameter } ;
parameter = IDENTIFIER , [ ":" , TYPE ] ;

type_union = TYPE , { "or" , TYPE } ;

(* --- If statements --- *)
if_statement = "if" , expression , ":" , NEWLINE , { statement } , [ "else" , ":" , NEWLINE , { statement } ] ;

(* --- Function calls --- *)
function_call = IDENTIFIER , "(" , [ arguments ] , ")" ;
arguments = expression , { "," , expression } ;

(* --- Expression statements --- *)
expression_statement = function_call ;
